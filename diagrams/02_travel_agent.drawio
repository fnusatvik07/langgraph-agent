<mxfile host="app.diagrams.net" type="device">
  <diagram name="Travel Agent (in-process)" id="travel-inproc">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Travel Agent - tools in-process" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=22;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="50" y="18" width="600" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="create_agent runs the model ↔ tools loop; the 4 tools are Python functions that call real APIs" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontStyle=2;fontColor=#777777;" vertex="1" parent="1">
          <mxGeometry x="50" y="48" width="760" height="20" as="geometry" />
        </mxCell>

        <!-- boundaries -->
        <mxCell id="procBox" value="Your Python process - travel_agent/" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;fillColor=#f3f8fd;strokeColor=#6c8ebf;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;fontStyle=1;fontColor=#3b6597;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="100" y="80" width="780" height="320" as="geometry" />
        </mxCell>
        <mxCell id="extBox" value="External APIs - called over HTTP" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;fillColor=#f7f7f7;strokeColor=#999999;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;fontStyle=1;fontColor=#666666;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="100" y="470" width="780" height="190" as="geometry" />
