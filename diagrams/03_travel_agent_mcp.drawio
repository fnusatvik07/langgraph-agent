<mxfile host="app.diagrams.net" type="device">
  <diagram name="Travel Agent (MCP)" id="travel-mcp">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1060" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Travel Agent - tools served over MCP (HTTP)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=22;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="50" y="16" width="700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Same agent as before - but the tools now live in a separate FastMCP server, loaded over the network" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontStyle=2;fontColor=#777777;" vertex="1" parent="1">
          <mxGeometry x="50" y="46" width="800" height="20" as="geometry" />
        </mxCell>

        <!-- process bands -->
        <mxCell id="agentProc" value="Agent process - travel_agent_mcp/" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;fillColor=#f3f8fd;strokeColor=#6c8ebf;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;fontStyle=1;fontColor=#3b6597;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="100" y="80" width="640" height="150" as="geometry" />
        </mxCell>
        <mxCell id="mcpProc" value="MCP Server - travel_mcp_server/  ·  FastMCP · HTTP :8000" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;fillColor=#fdf2ec;strokeColor=#d97757;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;fontStyle=1;fontColor=#b25b3c;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="100" y="330" width="720" height="150" as="geometry" />
        </mxCell>
        <mxCell id="extBox" value="External APIs - called over HTTP" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;fillColor=#f7f7f7;strokeColor=#999999;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;fontStyle=1;fontColor=#666666;fontSize=13;" vertex="1" parent="1">
