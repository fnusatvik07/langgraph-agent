<mxfile host="app.diagrams.net" type="device">
  <diagram name="ReAct Agent" id="react-agent">
    <mxGraphModel dx="1200" dy="780" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="740" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="ReAct Agent in LangGraph" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="60" y="22" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Reason → Act → Observe : the model ↔ tools loop" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=2;fontColor=#777777;" vertex="1" parent="1">
          <mxGeometry x="60" y="52" width="520" height="22" as="geometry" />
        </mxCell>

        <!-- boundary containers (behind) -->
        <mxCell id="agentBox" value="Compiled LangGraph - the agent" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;fillColor=#fdf6f3;strokeColor=#d97757;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;fontStyle=1;fontColor=#b25b3c;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="180" y="110" width="500" height="450" as="geometry" />
        </mxCell>
        <mxCell id="toolsBox" value="@tool functions" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;fillColor=#fff8ef;strokeColor=#d79b00;verticalAlign=top;align=left;spacingLeft=14;spacingTop=8;fontStyle=1;fontColor=#9a6b00;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="800" y="400" width="320" height="160" as="geometry" />
        </mxCell>

        <!-- user -->
        <mxCell id="user" value="User" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1f3a5f;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="300" width="50" height="80" as="geometry" />
        </mxCell>

        <!-- LLM cloud -->
        <mxCell id="llm" value="OpenAI · gpt-4o-mini&#10;(bound with tools)" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontColor=#5b3b73;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="28" width="240" height="92" as="geometry" />
        </mxCell>

        <!-- nodes -->
        <mxCell id="start" value="START" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontColor=#3a5a2a;" vertex="1" parent="1">
          <mxGeometry x="250" y="150" width="130" height="40" as="geometry" />
        </mxCell>
        <mxCell id="model" value="model node&#10;(Reason)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;fontColor=#1f3a5f;" vertex="1" parent="1">
          <mxGeometry x="240" y="250" width="160" height="72" as="geometry" />
        </mxCell>
        <mxCell id="decision" value="tool_calls?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontColor=#7a5b00;" vertex="1" parent="1">
          <mxGeometry x="460" y="250" width="150" height="72" as="geometry" />
        </mxCell>
        <mxCell id="toolnode" value="tool node&#10;(Act)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;fontColor=#1f3a5f;" vertex="1" parent="1">
          <mxGeometry x="240" y="440" width="160" height="72" as="geometry" />
        </mxCell>
        <mxCell id="end" value="END" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontColor=#3a5a2a;" vertex="1" parent="1">
          <mxGeometry x="470" y="372" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- tools -->
        <mxCell id="t1" value="add" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#7a4f00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="825" y="470" width="80" height="48" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="multiply" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#7a4f00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="470" width="95" height="48" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="divide" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#7a4f00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1030" y="470" width="75" height="48" as="geometry" />
        </mxCell>

        <!-- state caption -->
        <mxCell id="state" value="MessagesState&#10;the shared list of messages; add_messages appends one each step" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;size=16;fontColor=#3a5a2a;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="600" width="340" height="70" as="geometry" />
        </mxCell>

        <!-- edges -->
        <mxCell id="e_user" value="input" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5a5a5a;fontColor=#444444;endArrow=block;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="user" target="start">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_sm" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5a5a5a;endArrow=block;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.3;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="start" target="model">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_md" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5a5a5a;endArrow=block;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="model" target="decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_llm" value="calls the model&#10;messages → / ← tool_calls" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#9673a6;strokeWidth=1.5;startArrow=classic;endArrow=classic;fontColor=#5b3b73;exitX=0.8;exitY=0;entryX=0.3;entryY=1;" edge="1" parent="1" source="model" target="llm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_yes" value="has tool_calls" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5a5a5a;fontColor=#444444;endArrow=block;exitX=0.25;exitY=1;entryX=0.75;entryY=0;" edge="1" parent="1" source="decision" target="toolnode">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_no" value="no tool_calls" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5a5a5a;fontColor=#444444;endArrow=block;exitX=0.6;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="decision" target="end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_loop" value="results → loop" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d97757;strokeWidth=2.5;fontColor=#b25b3c;fontStyle=1;endArrow=block;exitX=0.3;exitY=0;entryX=0.3;entryY=1;" edge="1" parent="1" source="toolnode" target="model">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_exec" value="execute" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d79b00;fontColor=#9a6b00;endArrow=block;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="toolnode" target="toolsBox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_state" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;strokeColor=#82b366;endArrow=open;exitX=0.3;exitY=0;entryX=0.2;entryY=1;" edge="1" parent="1" source="state" target="agentBox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Travel Agent (in-process)" id="travel-inproc">
