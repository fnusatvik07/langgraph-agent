# Copy this file to .env inside each subfolder and fill in your values

# Required for all examples
OPENAI_API_KEY=sk-...

# SQLite (sqlite/)
SQLITE_DB_PATH=checkpoints.db   # path to the .db file

# PostgreSQL (postgres/)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/langgraph?sslmode=disable
# Supabase: postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres?sslmode=require

# MongoDB (mongodb/)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=langgraph
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/

# LLM model (optional, defaults to gpt-4o-mini)
MODEL=openai:gpt-4o-mini
